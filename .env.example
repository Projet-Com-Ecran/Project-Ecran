# Configuration Facebook TV Display

# ============================================
# TOKENS ET CREDENTIALS FACEBOOK
# ============================================

# Token d'accès Facebook Graph API (à longue durée)
# Générez-le depuis: https://developers.facebook.com/apps/
# Permissions requises: pages_read_engagement, pages_read_user_content
VITE_FACEBOOK_ACCESS_TOKEN=your_access_token_here

# ID de la Page Facebook
# Format numérique (ex: 123456789)
# Trouvez-le en cliquant sur "À propos" de la page
VITE_FACEBOOK_PAGE_ID=your_page_id_here

# ============================================
# CONFIGURATION DE L'APPLICATION
# ============================================

# Mode développement ou production
NODE_ENV=development
